# ============================================================
#  Norte Sur · Variables de entorno
#  Copia este archivo como `.env.local` y completa los valores.
# ============================================================

# ---- Supabase (Settings → API en tu proyecto) ----
NEXT_PUBLIC_SUPABASE_URL=https://TU-PROYECTO.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=tu-anon-key
# Clave secreta de servidor — NUNCA exponer en el cliente
SUPABASE_SERVICE_ROLE_KEY=tu-service-role-key

# ---- Resend (envío de correos de cotización / pedidos) ----
RESEND_API_KEY=tu-resend-api-key
# Remitente verificado en Resend (ej: "Norte Sur <ventas@huaipesypanos.cl>")
EMAIL_FROM=Norte Sur <onboarding@resend.dev>
# Correos que reciben las cotizaciones (separados por coma). También editable desde el admin.
QUOTE_NOTIFY_EMAILS=ventas@huaipesypanos.cl

# ---- Pasarela de pago (se conecta más adelante) ----
# Opción A: Flow (recomendado para partir)
FLOW_API_KEY=
FLOW_SECRET_KEY=
FLOW_BASE_URL=https://sandbox.flow.cl/api
# Opción B: Transbank Webpay Plus (migración futura)
TRANSBANK_COMMERCE_CODE=
TRANSBANK_API_KEY=
TRANSBANK_ENVIRONMENT=integration

# ---- App ----
NEXT_PUBLIC_SITE_URL=http://localhost:3000
